# Polymarket data API (no auth needed for the read endpoints we use)
POLY_DATA_API=https://data-api.polymarket.com

# Database path (relative to project root)
DB_PATH=data/polymarket.db

# Mode: 'paper' or 'live'. ALWAYS 'paper' until 60d of measured edge.
MODE=paper

# Gmail SMTP (for Step 6 email notifications)
# GMAIL_USER:         the sending Gmail address
# GMAIL_APP_PASSWORD: 16-char app password from myaccount.google.com/apppasswords
#                     (requires 2-Step Verification to be enabled on the account)
# EMAIL_TO:           recipient address (can differ from sender)
GMAIL_USER=
GMAIL_APP_PASSWORD=
EMAIL_TO=
